FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      batteryGasNMC;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    top
    {
        type            zeroGradient;
    }
    left
    {
        type            symmetryPlane;
    }
    inlet
    {
        type            zeroGradient;
    }
    wall_bottom
    {
        type            zeroGradient;
    }
    vent_1
    {
        type            fixedValue;
        value           uniform 1; 
    }
    wall_pack
    {
        type            zeroGradient;
    }
    wall_top
    {
        type            zeroGradient;
    }
    wall_side
    {
        type            zeroGradient;
    }
}


