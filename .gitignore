# OpenFOAM simulation result timesteps (root-level only)
/[0-9]*/
!/0.org/

# Generated mesh (rebuild with Allrun -> snappyHexMesh)
constant/polyMesh/
constant/extendedFeatureEdgeMesh/

# Generated log files
log.*

# HPC scheduler output
slurm-*.out

# ParaFoam artefacts
*.OpenFOAM

# postProcessing outputs (all generated by the solver)
postProcessing/

# Visualisation renders
images/

# Parallel decomposition directories
processor*/
